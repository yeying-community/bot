# 军队总开关
ARMY_ENABLE_CODEX=1
ARMY_ENABLE_SWARM=0

# 节奏（分钟）
ARMY_OBSERVE_INTERVAL_MIN=15
ARMY_VERIFY_INTERVAL_MIN=30
ARMY_ADVISOR_INTERVAL_MIN=60
ARMY_SWARM_INTERVAL_MIN=360

# 目录与运行
BOT_ROOT=/home/administrator/bot

# Router（可选，未设置时仅跳过 Router 探测）
ROUTER_BASE_URL=https://test-router.yeying.pub/v1
# ROUTER_API_KEY=

# Codex 运行配置（保持只读建议）
ARMY_CODEX_TIMEOUT_SEC=420
ARMY_CODEX_SANDBOX=read-only
