# =========================
# Coder Bot 配置模板
# =========================
# 用法：
# 1. 复制本文件为 config/coder-bot.env
# 2. 按注释填写自己的值
# 3. 运行 ./scripts/bootstrap.sh 或重启服务

# -------------------------
# 路径基准
# -------------------------
APP_HOME=..
DATA_DIR=data
SECRETS_DIR=secrets
LOG_DIR=data/logs

# -------------------------
# 服务监听地址
# -------------------------
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9081

# -------------------------
# GitHub App
# -------------------------
ENABLE_WEBHOOK=false
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_FORK_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem
GITHUB_CLONE_SSH_KEY_PATH=secrets/github-push-key
GITHUB_FORK_OWNER=your-github-name

# -------------------------
# 允许处理的仓库
# -------------------------
# 多个仓库用英文逗号分隔
# 示例：
# ALLOWED_REPOS=yeying-community/deployer,yeying-community/robot
ALLOWED_REPOS=upstream-owner/repo-name

# -------------------------
# 触发策略
# -------------------------
RUN_ON_ISSUE_OPENED=false
TRIGGER_LABEL=ai-run

# -------------------------
# 执行后端
# -------------------------
EXECUTION_BACKEND=openclaw
OPENCLAW_BIN=./scripts/openclaw-local
OPENCLAW_MODEL=router/gpt-5.4
OPENCLAW_TIMEOUT=1800
# OpenClaw 静态源配置，只放模型 / 飞书 / gateway 这类固定配置
OPENCLAW_CONFIG_PATH=config/openclaw.json
# OpenClaw 运行时配置，程序会自动生成，不建议手工编辑
OPENCLAW_RUNTIME_CONFIG_PATH=data/openclaw/runtime/openclaw.runtime.json
OPENCLAW_STATE_DIR=data/openclaw/state
OPENCLAW_SESSION_PREFIX=gh
ISSUE_BRANCH_PREFIX=coder
ROUTER_API_KEY=

# -------------------------
# Feishu handoff
# -------------------------
# 留空时，默认回退到 openclaw.json 里 groupAllowFrom 的第一个群。
FEISHU_HANDOFF_CHAT_ID=
FEISHU_ACCOUNT_ID=default
FEISHU_CONFIRM_KEYWORDS=/run,开始执行,确认执行,可以执行
FEISHU_THREAD_SCAN_LIMIT=30

# -------------------------
# 运行数据目录
# -------------------------
DB_PATH=data/issue_bot.db
JOB_ROOT=data/jobs
REPO_ROOT=data/repos
REPO_LOCK_WAIT_SECONDS=7200
ACTIVE_DIR=data/active
STATE_FILE=data/state.json
SYNC_SCRIPT_PATH=scripts/sync.sh

# -------------------------
# PR 行为
# -------------------------
PR_TITLE_PREFIX=[Coder]
# 可选：覆盖机器人提交代码时使用的 git author
GIT_AUTHOR_NAME=Coder
GIT_AUTHOR_EMAIL=coder-bot@local
SUBMIT_COMMENT_AFTER_PR=true
SUBMIT_COMMENT_BODY=/submit
DEFAULT_BASE_BRANCH=

# -------------------------
# 测试命令
# -------------------------
# 默认建议留空，只保留 OpenClaw 会话内的最小自检。
TEST_COMMAND=

# -------------------------
# 轮询与调度
# -------------------------
ENABLE_POLLING=true
POLL_INTERVAL_SECONDS=60
DISPATCH_INTERVAL_SECONDS=5
ISSUE_SCAN_LIMIT=30
FORK_WAIT_TIMEOUT_SECONDS=300
