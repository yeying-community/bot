# =========================
# Coding Bot 配置模板
# =========================
# 用法：
# 1. 复制本文件为 .env
# 2. 按注释把每一项改成你自己的值
# 3. 改完后重启 coding-bot 服务

# -------------------------
# 路径基准
# -------------------------
# 一般保持默认即可
APP_HOME=.
DATA_DIR=data
SECRETS_DIR=secrets

# -------------------------
# 服务监听地址
# -------------------------
# polling-only 和可选 webhook 共用这个端口
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9081

# -------------------------
# GitHub App
# -------------------------
# 默认推荐 polling-only 部署，不依赖 webhook 和 nginx
ENABLE_WEBHOOK=false
# 仅在 ENABLE_WEBHOOK=true 时需要填写
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_FORK_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem
GITHUB_FORK_OWNER=your-github-name

# -------------------------
# 允许处理的仓库
# -------------------------
# 多个仓库用英文逗号分隔，不要换行
# 示例：
# ALLOWED_REPOS=yeying-community/deployer,yeying-community/another-repo,foo/bar
ALLOWED_REPOS=upstream-owner/repo-name

# -------------------------
# 触发策略
# -------------------------
RUN_ON_ISSUE_OPENED=false
TRIGGER_LABEL=ai-run
TRIGGER_COMMENT=/run

# -------------------------
# Codex
# -------------------------
# 建议写绝对路径，避免系统里有多个 codex 安装时命中错误版本
# 如果目标机器只有 root 用户，直接写 root 下的 codex 路径
# 示例：CODEX_BIN=/root/.npm-global/bin/codex
CODEX_BIN=/root/.npm-global/bin/codex
CODEX_MODEL=gpt-5.4
CODEX_TIMEOUT=1800
# 如果目标机器只有 root 用户，这里直接写 /root/.codex
CODEX_SOURCE_HOME=/root/.codex
CODEX_RUNTIME_HOME=data/codex-runtime

# -------------------------
# 运行数据目录
# -------------------------
DB_PATH=data/issue_bot.db
JOB_ROOT=data/jobs
REPO_ROOT=data/repos
REPO_LOCK_WAIT_SECONDS=7200
ACTIVE_DIR=data/active
SYNC_SCRIPT_PATH=scripts/sync.sh
MERGE_SCRIPT_PATH=scripts/merge.sh

# -------------------------
# Git 提交身份
# -------------------------
GIT_AUTHOR_NAME=Codex Bot
GIT_AUTHOR_EMAIL=codex-bot@example.com

# -------------------------
# PR 行为
# -------------------------
PR_TITLE_PREFIX=[Codex]
SUBMIT_COMMENT_AFTER_PR=true
SUBMIT_COMMENT_BODY=/submit
DEFAULT_BASE_BRANCH=

# -------------------------
# 测试命令
# -------------------------
# 默认建议留空，只保留 Codex 在任务内做最小必要自检
# 只有你明确需要外层机器人额外执行固定 shell 测试时，才填写 TEST_COMMAND
TEST_COMMAND=

# -------------------------
# 飞书通知
# -------------------------
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# -------------------------
# 轮询与调度
# -------------------------
ENABLE_POLLING=true
POLL_INTERVAL_SECONDS=60
DISPATCH_INTERVAL_SECONDS=5
STATE_FILE=data/state.json
ISSUE_SCAN_LIMIT=30
COMMENT_SCAN_LIMIT=30
FORK_WAIT_TIMEOUT_SECONDS=300

# -------------------------
# Git SSH
# -------------------------
GITHUB_CLONE_MODE=ssh
GITHUB_CLONE_SSH_KEY_PATH=secrets/github-push-key
